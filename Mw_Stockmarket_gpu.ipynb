    {
      "cell_type": "code",
      "source": [
        "# Fix: pull models properly (ignore 502 cloudflare errors - retry until success)\n",
        "import subprocess, time\n",
        "\n",
        "def pull_with_retry(model, retries=5):\n",
        "    for i in range(retries):\n",
        "        print(f\"Pulling {model} (attempt {i+1})...\")\n",
        "        result = subprocess.run([\"ollama\", \"pull\", model], capture_output=True, text=True, timeout=300)\n",
        "        if result.returncode == 0 or 'already' in result.stdout.lower() or 'success' in result.stdout.lower():\n",
        "            print(f\"✅ {model} ready\")\n",
        "            return True\n",
        "        print(f\"  stdout: {result.stdout[-200:]}\")\n",
        "        print(f\"  stderr: {result.stderr[-200:]}\")\n",
        "        print(f\"  Retrying in 10s...\")\n",
        "        time.sleep(10)\n",
        "    return False\n",
        "\n",
        "pull_with_retry(\"mistral:latest\")\n",
        "pull_with_retry(\"nomic-embed-text:latest\")\n",
        "\n",
        "# Verify\n",
        "r = subprocess.run([\"ollama\", \"list\"], capture_output=True, text=True)\n",
        "print(\"\\nInstalled models:\")\n",
        "print(r.stdout)\n"
      ],
      "metadata": {
        "id": "fix_pull_cell"
      },
