    {
      "cell_type": "code",
      "source": [
        "import subprocess, threading, time, os\n",
        "\n",
        "# Set env to listen on all interfaces\n",
        "env = os.environ.copy()\n",
        "env[\"OLLAMA_HOST\"] = \"0.0.0.0\"\n",
        "\n",
        "def run_ollama():\n",
        "    subprocess.run([\"ollama\", \"serve\"], env=env)\n",
        "\n",
        "thread = threading.Thread(target=run_ollama, daemon=True)\n",
        "thread.start()\n",
        "time.sleep(8)\n",
        "\n",
        "# Verify it's running\n",
        "import urllib.request\n",
        "try:\n",
        "    r = urllib.request.urlopen(\"http://localhost:11434/api/tags\", timeout=5)\n",
        "    print(\"✅ Ollama is running!\")\n",
        "except Exception as e:\n",
        "    print(f\"❌ Not running: {e}\")\n",
        "\n",
        "# Check GPU\n",
        "!nvidia-smi | head -15\n"
      ],
