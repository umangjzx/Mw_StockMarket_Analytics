# ── Application ──────────────────────────────────────────────────────────
APP_ENV=development                     # development | staging | production
APP_DEBUG=true
SECRET_KEY=changeme-use-openssl-rand-hex-32
APP_NAME="MW StockMarket Analytics"

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mw_user:mw_pass@localhost:5432/mw_stockmarket
DATABASE_URL_SYNC=postgresql://mw_user:mw_pass@localhost:5432/mw_stockmarket
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── YouTube Data API ──────────────────────────────────────────────────────
YOUTUBE_API_KEY=your-youtube-api-key-here
YOUTUBE_DAILY_QUOTA_LIMIT=10000         # default YouTube Data API v3 daily quota units

# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_LLM_MODEL=gpt-4o-mini            # model for analysis tasks
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=4096
OPENAI_DAILY_SPEND_LIMIT=10.00          # USD, triggers alerts above this

# ── Transcription ─────────────────────────────────────────────────────────
WHISPER_MODE=local                      # local | openai_api
WHISPER_MODEL_SIZE=base                 # tiny | base | small | medium | large-v2
WHISPER_DEVICE=cpu                      # cpu | cuda

# ── JWT Auth ──────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Admin ─────────────────────────────────────────────────────────────────
ADMIN_API_KEY=changeme-admin-key

# ── Object Storage ────────────────────────────────────────────────────────
STORAGE_BACKEND=local                   # local | s3
MEDIA_CACHE_DIR=/tmp/mw_media_cache
MEDIA_RETENTION_HOURS=24               # how long raw audio is kept before cleanup

# AWS S3 (used when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1

# ── Observability ─────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true

# ── Celery / Workers ─────────────────────────────────────────────────────
CELERY_TASK_ALWAYS_EAGER=false          # set true in tests to run tasks synchronously
MAX_PIPELINE_RETRIES=5
PIPELINE_RETRY_BACKOFF_MAX=600         # seconds
